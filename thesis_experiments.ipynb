"""
Jupyter Notebook-based experimental interface for ANN-to-SNN conversion.

This notebook provides a step-by-step, interactive exploration of the conversion pipeline.
Ideal for thesis documentation and iterative research.

Usage:
  jupyter notebook thesis_experiments.ipynb

Structure:
  1. Setup & Configuration
  2. Data Loading and Exploration
  3. ANN Training
  4. Activation Analysis
  5. SNN Calibration
  6. Comparative Evaluation
  7. Results Visualization
"""

# ============================================================================
# CELL 1: Imports and Setup
# ============================================================================

import torch
import torch.nn as nn
import numpy as np
import matplotlib.pyplot as plt
from pathlib import Path
from tqdm.notebook import tqdm
import json

# Project imports
from data import load_data, get_class_names
from ann_model import create_model
from train_ann import ANNTrainer
from calibration import calibrate_and_compute_thresholds
from snn_model import create_snn, rate_code_input
from evaluate import evaluate_ann, evaluate_snn, print_evaluation_summary
from utils import setup_device, set_seed, print_model_summary

# Configure visualization
plt.style.use('seaborn-v0_8-darkgrid')
%matplotlib inline

print("✓ All imports successful!")

# ============================================================================
# CELL 2: Configuration
# ============================================================================

# Experimental configuration
CONFIG = {
    'seed': 42,
    'device': 'cuda' if torch.cuda.is_available() else 'cpu',
    'dataset': 'cifar10',
    'batch_size': 128,
    'num_workers': 4,
    'learning_rate': 0.001,
    'weight_decay': 1e-4,
    'epochs': 50,  # Reduced for faster iteration
    'time_steps': 100,
    'vth_percentile': 99.0,
    'threshold_scale': 1.0,
    'calibration_samples': 1000,
    'checkpoint_dir': './checkpoints',
}

print("\n" + "="*70)
print("EXPERIMENT CONFIGURATION")
print("="*70)
for key, value in CONFIG.items():
    print(f"{key:.<30} {value}")
print("="*70 + "\n")

# Setup
set_seed(CONFIG['seed'])
device = setup_device(CONFIG['device'])
Path(CONFIG['checkpoint_dir']).mkdir(exist_ok=True)

# ============================================================================
# CELL 3: Load and Explore Data
# ============================================================================

print("Loading CIFAR-10 dataset...")
train_loader, val_loader, test_loader = load_data(
    dataset_name=CONFIG['dataset'],
    batch_size=CONFIG['batch_size'],
    num_workers=CONFIG['num_workers'],
    val_split=0.1
)

class_names = get_class_names(CONFIG['dataset'])
print(f"Classes: {class_names}")

# Visualize sample images
images, labels = next(iter(train_loader))
fig, axes = plt.subplots(2, 5, figsize=(12, 5))
for i, ax in enumerate(axes.flatten()):
    # Denormalize
    img = images[i].permute(1, 2, 0)
    ax.imshow(img)
    ax.set_title(class_names[labels[i]])
    ax.axis('off')
plt.tight_layout()
plt.title("Sample CIFAR-10 Images")
plt.show()

# ============================================================================
# CELL 4: Train ANN
# ============================================================================

print("\nCreating ANN model...")
ann_model = create_model(
    architecture="simple",
    num_classes=10,
    device=device
)
print_model_summary(ann_model, "SimpleCNN")

print("\nInitializing trainer...")
trainer = ANNTrainer(
    ann_model,
    device,
    learning_rate=CONFIG['learning_rate'],
    weight_decay=CONFIG['weight_decay']
)

print("\nTraining ANN...")
history = trainer.fit(
    train_loader,
    val_loader,
    epochs=CONFIG['epochs'],
    checkpoint_dir=CONFIG['checkpoint_dir'],
    early_stopping_patience=10
)

print(f"\n✓ Training complete! Best validation accuracy: {trainer.best_val_acc:.4f}")

# ============================================================================
# CELL 5: Visualize Training History
# ============================================================================

fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 4))

# Loss
ax1.plot(history['train_loss'], label='Train', marker='o', markersize=3)
ax1.plot(history['val_loss'], label='Val', marker='s', markersize=3)
ax1.set_xlabel('Epoch')
ax1.set_ylabel('Loss')
ax1.set_title('Training and Validation Loss')
ax1.legend()
ax1.grid(True)

# Accuracy
ax2.plot(history['train_acc'], label='Train', marker='o', markersize=3)
ax2.plot(history['val_acc'], label='Val', marker='s', markersize=3)
ax2.set_xlabel('Epoch')
ax2.set_ylabel('Accuracy')
ax2.set_title('Training and Validation Accuracy')
ax2.legend()
ax2.grid(True)

plt.tight_layout()
plt.show()

# ============================================================================
# CELL 6: Evaluate ANN on Test Set
# ============================================================================

print("Evaluating ANN on test set...")
ann_results = evaluate_ann(ann_model, test_loader, device)

print(f"\nANN Test Accuracy: {ann_results['overall_accuracy']:.4f}")
print(f"Total Samples: {ann_results['total_samples']}")

# Per-class accuracy
print("\nPer-class Accuracy (ANN):")
for class_id, acc in ann_results['per_class_accuracy'].items():
    print(f"  {class_names[class_id]:.<20} {acc:.4f}")

# ============================================================================
# CELL 7: Activation Analysis
# ============================================================================

from calibration import ActivationCollector

print("\nAnalyzing ANN activations for calibration...")
from torch.utils.data import Subset

calibration_set = Subset(
    val_loader.dataset,
    range(min(CONFIG['calibration_samples'], len(val_loader.dataset)))
)
calibration_loader = torch.utils.data.DataLoader(
    calibration_set,
    batch_size=CONFIG['batch_size'],
    shuffle=False,
    num_workers=CONFIG['num_workers']
)

# Collect activations
from calibration import collect_activations
activation_stats = collect_activations(ann_model, calibration_loader, device)

# Visualize activation distributions
fig, axes = plt.subplots(1, 3, figsize=(15, 4))
layer_names = list(activation_stats.keys())

for idx, (ax, layer_name) in enumerate(zip(axes, layer_names)):
    stats = activation_stats[layer_name]
    percentile_99 = stats['percentile_99']
    
    # Create histogram data
    ax.axvline(percentile_99, color='r', linestyle='--', label=f'99th: {percentile_99:.2f}')
    ax.set_title(f"Activation Distribution: {layer_name}")
    ax.set_xlabel("Activation Value")
    ax.set_ylabel("Frequency")
    ax.legend()
    ax.grid(True, alpha=0.3)

plt.tight_layout()
plt.show()

print("\nActivation Statistics Summary:")
for layer_name, stats in activation_stats.items():
    print(f"\n{layer_name}:")
    print(f"  Range: [{stats['min']:.4f}, {stats['max']:.4f}]")
    print(f"  Mean: {stats['mean']:.4f}, Std: {stats['std']:.4f}")
    print(f"  99th percentile: {stats['percentile_99']:.4f}")

# ============================================================================
# CELL 8: Calibrate Thresholds and Convert to SNN
# ============================================================================

from calibration import compute_thresholds

print("\nCalibrating thresholds...")
thresholds = compute_thresholds(
    activation_stats,
    percentile=CONFIG['vth_percentile'],
    scale=CONFIG['threshold_scale']
)

print(f"\nCalibrated Thresholds:")
for layer_name, vth in thresholds.items():
    print(f"  {layer_name:.<20} V_th = {vth:.4f}")

print("\nConverting to SNN...")
snn_model = create_snn(
    ann_model,
    thresholds,
    num_classes=10,
    device=device
)

print("✓ SNN conversion complete!")

# ============================================================================
# CELL 9: Evaluate SNN
# ============================================================================

print("\nEvaluating SNN on test set (T={} time steps)...".format(CONFIG['time_steps']))
snn_results = evaluate_snn(
    snn_model,
    test_loader,
    device,
    time_steps=CONFIG['time_steps']
)

print(f"\nSNN Test Accuracy: {snn_results['overall_accuracy']:.4f}")
print(f"Accuracy Drop: {(ann_results['overall_accuracy'] - snn_results['overall_accuracy'])*100:.2f}%")

print(f"\nPer-class Accuracy (SNN):")
for class_id, acc in snn_results['per_class_accuracy'].items():
    ann_acc = ann_results['per_class_accuracy'][class_id]
    diff = (ann_acc - acc) * 100
    print(f"  {class_names[class_id]:.<20} {acc:.4f} (ANN: {ann_acc:.4f}, Δ: {diff:+.2f}%)")

print(f"\nAverage Firing Rates (SNN):")
for layer_name, firing_rate in snn_results['average_firing_rates'].items():
    sparsity = (1 - firing_rate) * 100
    print(f"  {layer_name:.<20} {firing_rate:.2%} (sparsity: {sparsity:.1f}%)")

# ============================================================================
# CELL 10: Comprehensive Comparison
# ============================================================================

print_evaluation_summary(ann_results, snn_results)

# ============================================================================
# CELL 11: Visualization - ANN vs SNN
# ============================================================================

fig, axes = plt.subplots(2, 2, figsize=(12, 10))

# Overall accuracy comparison
ax = axes[0, 0]
models = ['ANN', 'SNN']
accuracies = [ann_results['overall_accuracy'], snn_results['overall_accuracy']]
colors = ['#2E86AB', '#A23B72']
ax.bar(models, accuracies, color=colors, alpha=0.7, edgecolor='black', linewidth=2)
ax.set_ylabel('Accuracy')
ax.set_title('Overall Test Accuracy')
ax.set_ylim([0, 1])
for i, acc in enumerate(accuracies):
    ax.text(i, acc + 0.02, f'{acc:.4f}', ha='center', fontweight='bold')
ax.grid(True, alpha=0.3, axis='y')

# Per-class accuracy comparison
ax = axes[0, 1]
class_ids = sorted(ann_results['per_class_accuracy'].keys())
ann_accs = [ann_results['per_class_accuracy'][cid] for cid in class_ids]
snn_accs = [snn_results['per_class_accuracy'][cid] for cid in class_ids]
x = np.arange(len(class_ids))
width = 0.35
ax.bar(x - width/2, ann_accs, width, label='ANN', color='#2E86AB', alpha=0.7)
ax.bar(x + width/2, snn_accs, width, label='SNN', color='#A23B72', alpha=0.7)
ax.set_ylabel('Accuracy')
ax.set_title('Per-Class Accuracy')
ax.set_xticks(x)
ax.set_xticklabels([class_names[cid] for cid in class_ids], rotation=45, ha='right')
ax.legend()
ax.grid(True, alpha=0.3, axis='y')

# Firing rates by layer
ax = axes[1, 0]
layer_names = list(snn_results['average_firing_rates'].keys())
firing_rates = list(snn_results['average_firing_rates'].values())
colors_fire = ['#F18F01', '#C73E1D', '#6A994E']
ax.bar(layer_names, firing_rates, color=colors_fire, alpha=0.7, edgecolor='black', linewidth=2)
ax.set_ylabel('Firing Rate')
ax.set_title('Average Firing Rates (Sparsity)')
ax.set_ylim([0, 1])
for i, fr in enumerate(firing_rates):
    sparsity = (1 - fr) * 100
    ax.text(i, fr + 0.02, f'{sparsity:.0f}%', ha='center', fontweight='bold')
ax.grid(True, alpha=0.3, axis='y')

# Accuracy drop per class
ax = axes[1, 1]
accuracy_drops = [(ann_results['per_class_accuracy'][cid] - snn_results['per_class_accuracy'][cid]) * 100
                 for cid in class_ids]
colors_drop = ['#D62828' if drop > 2 else '#2A9D8F' for drop in accuracy_drops]
ax.bar([class_names[cid] for cid in class_ids], accuracy_drops, color=colors_drop, alpha=0.7, edgecolor='black')
ax.set_ylabel('Accuracy Drop (%)')
ax.set_title('ANN-SNN Accuracy Gap')
ax.axhline(y=0, color='black', linestyle='-', linewidth=0.5)
ax.set_xticklabels([class_names[cid] for cid in class_ids], rotation=45, ha='right')
ax.grid(True, alpha=0.3, axis='y')

plt.tight_layout()
plt.show()

# ============================================================================
# CELL 12: Save Results
# ============================================================================

print("\nSaving experimental results...")

# Save models
ann_path = Path(CONFIG['checkpoint_dir']) / 'ann_notebook.pth'
snn_path = Path(CONFIG['checkpoint_dir']) / 'snn_notebook.pth'

torch.save(ann_model.state_dict(), ann_path)
torch.save(snn_model.state_dict(), snn_path)

# Save results
results_summary = {
    'config': CONFIG,
    'ann_accuracy': ann_results['overall_accuracy'],
    'snn_accuracy': snn_results['overall_accuracy'],
    'accuracy_drop_percent': (ann_results['overall_accuracy'] - snn_results['overall_accuracy']) * 100,
    'thresholds': {k: float(v) for k, v in thresholds.items()},
    'firing_rates': {k: float(v) for k, v in snn_results['average_firing_rates'].items()},
    'time_steps': CONFIG['time_steps'],
}

results_path = Path(CONFIG['checkpoint_dir']) / 'results_notebook.json'
with open(results_path, 'w') as f:
    json.dump(results_summary, f, indent=2)

print(f"✓ ANN saved: {ann_path}")
print(f"✓ SNN saved: {snn_path}")
print(f"✓ Results saved: {results_path}")

# ============================================================================
# CELL 13: Summary and Insights
# ============================================================================

print("\n" + "="*70)
print("EXPERIMENT SUMMARY")
print("="*70)

print(f"\n[Dataset] {CONFIG['dataset'].upper()}")
print(f"  Samples: {ann_results['total_samples']}")
print(f"  Classes: {len(class_names)}")

print(f"\n[ANN Training]")
print(f"  Epochs: {CONFIG['epochs']}")
print(f"  Test Accuracy: {ann_results['overall_accuracy']:.4f}")
print(f"  Training Time: ~{CONFIG['epochs']} minutes (GPU-dependent)")

print(f"\n[SNN Conversion]")
print(f"  Time Steps: {CONFIG['time_steps']}")
print(f"  Test Accuracy: {snn_results['overall_accuracy']:.4f}")
print(f"  Accuracy Drop: {(ann_results['overall_accuracy'] - snn_results['overall_accuracy'])*100:.2f}%")
print(f"  Average Sparsity: {(1 - np.mean(list(snn_results['average_firing_rates'].values())))*100:.1f}%")

print(f"\n[Calibration]")
print(f"  Calibration Samples: {CONFIG['calibration_samples']}")
print(f"  Percentile: {CONFIG['vth_percentile']:.1f}")
print(f"  Threshold Scale: {CONFIG['threshold_scale']}")

print(f"\n[Key Findings]")
accuracy_loss = (ann_results['overall_accuracy'] - snn_results['overall_accuracy']) * 100
if accuracy_loss < 2:
    print(f"  ✓ Excellent conversion! ANN-SNN gap < 2%")
elif accuracy_loss < 5:
    print(f"  ~ Good conversion. ANN-SNN gap < 5%")
else:
    print(f"  ! Consider recalibration. ANN-SNN gap > 5%")

avg_sparsity = (1 - np.mean(list(snn_results['average_firing_rates'].values()))) * 100
print(f"  ✓ High sparsity achieved: {avg_sparsity:.1f}%")
print(f"  ✓ Suitable for neuromorphic hardware deployment")

print("\n" + "="*70)
print("END OF NOTEBOOK")
print("="*70 + "\n")
